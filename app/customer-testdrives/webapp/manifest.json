{
  "_version": "1.28.0",
  "sap.app": {
    "id": "automarket.customertestdrives",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "automarket-manual-fe-writer",
      "version": "1.0.0"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/catalog/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.84.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "automarket.customertestdrives.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "TestDrivesList",
          "target": "TestDrivesList"
        },
        {
          "pattern": "TestDrives({key}):?query:",
          "name": "TestDrivesObjectPage",
          "target": "TestDrivesObjectPage"
        }
      ],
      "targets": {
        "TestDrivesList": {
          "type": "Component",
          "id": "TestDrivesList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "TestDrives",
              "variantManagement": "Page",
              "navigation": {
                "TestDrives": {
                  "detail": {
                    "route": "TestDrivesObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              },
              "content": {
                "header": {
                  "actions": {
                    "NavCatalog": {
                      "id": "NavCatalog",
                      "press": "automarket.customertestdrives.ext.CustomActions.onNavCatalog",
                      "text": "Vehicle Catalog",
                      "enabled": true,
                      "visible": true
                    },
                    "NavReservations": {
                      "id": "NavReservations",
                      "press": "automarket.customertestdrives.ext.CustomActions.onNavReservations",
                      "text": "My Reservations",
                      "enabled": true,
                      "visible": true
                    },
                    "NavOffers": {
                      "id": "NavOffers",
                      "press": "automarket.customertestdrives.ext.CustomActions.onNavOffers",
                      "text": "My Offers",
                      "enabled": true,
                      "visible": true
                    },
                    "NavOrders": {
                      "id": "NavOrders",
                      "press": "automarket.customertestdrives.ext.CustomActions.onNavOrders",
                      "text": "My Orders",
                      "enabled": true,
                      "visible": true
                    },
                    "NavPayments": {
                      "id": "NavPayments",
                      "press": "automarket.customertestdrives.ext.CustomActions.onNavPayments",
                      "text": "My Payments",
                      "enabled": true,
                      "visible": true
                    },
                    "Logout": {
                      "id": "Logout",
                      "press": "automarket.customertestdrives.ext.CustomActions.onLogout",
                      "text": "Logout",
                      "enabled": true,
                      "visible": true
                    }
                  }
                }
              }
            }
          }
        },
        "TestDrivesObjectPage": {
          "type": "Component",
          "id": "TestDrivesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "entitySet": "TestDrives",
              "content": {
                "header": {
                  "actions": {
                    "BackToList": {
                      "id": "BackToList",
                      "press": "automarket.customertestdrives.ext.CustomActions.onBackToList",
                      "text": "Back to List",
                      "enabled": true,
                      "visible": true
                    },
                    "Logout": {
                      "id": "Logout",
                      "press": "automarket.customertestdrives.ext.CustomActions.onLogout",
                      "text": "Logout",
                      "enabled": true,
                      "visible": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}

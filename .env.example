# Copy this file to .env and fill in real values before running the app with
# anything other than plain `npm start`/`npm test` (those work with zero
# configuration — see docs/dev-notes.md §6 for exactly which of these are
# actually required in which environment). Never commit a real .env file
# (already in .gitignore).

# --- Application secrets ---------------------------------------------------
# Required whenever NODE_ENV=production. In local/dev/test, JWT_SECRET has no
# fallback (the app refuses to start without it, in every environment);
# GUEST_TOKEN_SECRET falls back to a known, insecure dev-only value unless
# NODE_ENV=production, in which case it's required too (EPIC23-T6 — see
# modules/reservation/infrastructure/guest-token.js).
JWT_SECRET=change-me-to-a-long-random-string
GUEST_TOKEN_SECRET=change-me-to-a-different-long-random-string

# Selects the active auth provider in infrastructure/auth/index.js.
# Valid values: local | xsuaa | guest. Defaults to "local" if unset — only
# needs to be set explicitly to switch away from that default.
# AUTH_PROVIDER=local

# --- PostgreSQL (docker-compose / EPIC23-T1/T4) ----------------------------
# Only read by docker-compose.yml (the [hybrid] cds profile) and, in a real
# deployment, by whatever supplies CDS_REQUIRES_DB_CREDENTIALS_* directly
# (a bound BTP service, or these same POSTGRES_* values via a different
# mechanism) — irrelevant for the default SQLite-backed `npm start`/`npm test`.
POSTGRES_DB=automarket
POSTGRES_USER=automarket
POSTGRES_PASSWORD=change-me-locally

{
  "name": "automarket",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4"
  },
  "scripts": {
    "start": "cds-serve",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --passWithNoTests"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "admin": {
            "password": "admin",
            "roles": [
              "Admin"
            ]
          },
          "manager": {
            "password": "manager",
            "roles": [
              "Manager"
            ]
          },
          "operator": {
            "password": "operator",
            "roles": [
              "Operator"
            ],
            "attr": {
              "branchId": "00000000-0000-0000-0000-000000000001"
            }
          },
          "customer": {
            "password": "customer",
            "roles": [
              "Customer"
            ]
          }
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      },
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": ":memory:"
        }
      }
    },
    "services": {
      "IdentityService": {
        "impl": "modules/identity/application/identity-service.js"
      },
      "BranchService": {
        "impl": "modules/branch/application/branch-service.js"
      },
      "VehicleService": {
        "impl": "modules/vehicle/application/vehicle-service.js"
      },
      "OperatorPortalService": {
        "impl": "modules/vehicle/application/operator-portal.js"
      },
      "CustomerPortalService": {
        "impl": "modules/vehicle/application/customer-portal.js"
      }
    }
  }
}
